# ─────────────────────────────────────────────
# apps/api (NestJS — Railway)
#
# Railway UI setup:
#   1. New Project → Deploy from GitHub → finicafferata/influencers
#   2. Set Root Directory: / (repo root — needed for monorepo lockfile)
#   3. Add env var: NIXPACKS_CONFIG_FILE=apps/api/nixpacks.toml
#   4. Add a PostgreSQL service and copy its DATABASE_URL here
# ─────────────────────────────────────────────

# Required by Nixpacks to find the build config when root is set to repo root
NIXPACKS_CONFIG_FILE=apps/api/nixpacks.toml

# PostgreSQL connection string (provided by Railway PostgreSQL service)
# Railway → Project → PostgreSQL service → Connect → DATABASE_URL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT secret for magic link tokens — generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here-min-32-chars

# Google OAuth credentials (console.cloud.google.com → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Transactional email (resend.com → API Keys)
RESEND_API_KEY=

# Origin allowed for CORS (set to your Vercel deployment URL in production)
WEB_URL=http://localhost:3000

# Port (Railway sets this automatically; fallback for local dev)
PORT=3001

# ─────────────────────────────────────────────
# apps/web (Next.js — Vercel)
#
# Vercel UI setup:
#   1. New Project → Import finicafferata/influencers
#   2. Set Root Directory: apps/web
#   3. Framework Preset: Next.js (auto-detected)
#   4. Override Build Command: cd ../.. && pnpm build --filter=web
#   5. Override Install Command: pnpm install
# ─────────────────────────────────────────────

# Internal URL of the NestJS API used by server-side tRPC client
# In Railway: use the private service URL (e.g. http://api.railway.internal:3001)
API_URL=http://localhost:3001

# Public URL of the NestJS API used by browser-side tRPC client
NEXT_PUBLIC_API_URL=http://localhost:3001
